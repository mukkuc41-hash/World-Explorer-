{
  "entities": {
    "Location": {
      "title": "Location",
      "description": "A tourist location shared by a user.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "The name of the location." },
        "description": { "type": "string", "description": "A detailed description of the location." },
        "imageUrl": { "type": "string", "description": "URL of the location's image." },
        "continent": { 
          "type": "string", 
          "enum": ["Africa", "Asia", "Europe", "North America", "South America", "Oceania", "Antarctica"],
          "description": "The continent where the location is situated." 
        },
        "country": { "type": "string", "description": "The country where the location is situated." },
        "state": { "type": "string", "description": "The state or region where the location is situated." },
        "userId": { "type": "string", "description": "The UID of the user who added the location." },
        "userName": { "type": "string", "description": "The name of the user who added the location." },
        "lat": { "type": "number", "description": "Latitude of the location." },
        "lng": { "type": "number", "description": "Longitude of the location." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the location was created." },
        "updatedAt": { "type": "string", "format": "date-time", "description": "When the location was last updated." }
      },
      "required": ["name", "description", "imageUrl", "continent", "userId", "userName", "createdAt", "updatedAt"]
    },
    "Review": {
      "title": "Review",
      "description": "A user's review for a location.",
      "type": "object",
      "properties": {
        "locationId": { "type": "string", "description": "The ID of the location being reviewed." },
        "userId": { "type": "string", "description": "The UID of the reviewer." },
        "userName": { "type": "string", "description": "The name of the reviewer." },
        "rating": { "type": "number", "description": "Rating from 1 to 5." },
        "comment": { "type": "string", "description": "The review text." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the review was created." }
      },
      "required": ["locationId", "userId", "userName", "rating", "comment", "createdAt"]
    },
    "Favorite": {
      "title": "Favorite",
      "description": "A user's marked favorite location.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The UID of the user who favorited the location." },
        "locationId": { "type": "string", "description": "The ID of the favorited location." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the favorite was created." }
      },
      "required": ["userId", "locationId", "createdAt"]
    },
    "PlannedVisit": {
      "title": "Planned Visit",
      "description": "A location planned for a future tour.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The UID of the user planning the visit." },
        "locationId": { "type": "string", "description": "The ID of the location to visit." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the visit was planned." }
      },
      "required": ["userId", "locationId", "createdAt"]
    },
    "Archive": {
      "title": "Archive",
      "description": "A location saved to the user's personal archive.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The UID of the user archiving the item." },
        "locationId": { "type": "string", "description": "The ID of the archived location." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When it was archived." }
      },
      "required": ["userId", "locationId", "createdAt"]
    },
    "PublicProfile": {
      "title": "Public Profile",
      "description": "Publicly visible user information for leaderboards and social features.",
      "type": "object",
      "properties": {
        "displayName": { "type": "string", "description": "User's display name." },
        "photoURL": { "type": "string", "description": "User's profile photo URL." },
        "points": { "type": "number", "description": "User's total experience points." },
        "totalDiscoveries": { "type": "number", "description": "Total locations shared." },
        "totalReviews": { "type": "number", "description": "Total reviews written." },
        "updatedAt": { "type": "string", "format": "date-time", "description": "When the profile was last updated." }
      },
      "required": ["displayName", "updatedAt"]
    },
    "UserProfile": {
      "title": "UserProfile",
      "description": "Information about a registered user.",
      "type": "object",
      "properties": {
        "firstName": { "type": "string", "description": "User's first name." },
        "lastName": { "type": "string", "description": "User's last name." },
        "username": { "type": "string", "description": "User's unique username." },
        "email": { "type": "string", "description": "User's email address." },
        "phoneNumber": { "type": "string", "description": "User's phone number." },
        "birthDate": { "type": "string", "description": "User's date of birth." },
        "gender": { "type": "string", "description": "User's gender." },
        "streakCount": { "type": "number", "description": "Current consecutive days of active app usage." },
        "longestStreak": { "type": "number", "description": "The user's maximum recorded active streak." },
        "lastActiveDate": { "type": "string", "description": "The last date (YYYY-MM-DD) the user was active." },
        "updatedAt": { "type": "string", "format": "date-time", "description": "When the profile was last updated." }
      },
      "required": ["email", "updatedAt"]
    }
  },
  "firestore": {
    "locations": {
      "schema": "Location",
      "description": "Collection of community-shared tourist locations."
    },
    "reviews": {
      "schema": "Review",
      "description": "User reviews and ratings for locations."
    },
    "favorites": {
      "schema": "Favorite",
      "description": "Collection of user-to-location favorite mappings."
    },
    "tours": {
      "schema": "PlannedVisit",
      "description": "Locations saved to a user's 'Next Tour' itinerary."
    },
    "archives": {
      "schema": "Archive",
      "description": "User-specific archived discoveries."
    },
    "users": {
      "schema": "UserProfile",
      "description": "Collection of user profile data."
    },
    "public_profiles": {
      "schema": "PublicProfile",
      "description": "Public user profiles for leaderboard."
    }
  }
}
