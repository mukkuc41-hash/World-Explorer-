rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // --- Global Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      return isSignedIn();
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isVerified() && (
        request.auth.token.email == 'mukkuc41@gmail.com' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Validation Helpers ---
    function isValidUserProfile(data) {
      return (!data.keys().contains('email') || (data.email is string && data.email.size() <= 256))
        && (!data.keys().contains('updatedAt') || data.updatedAt is timestamp)
        && (!data.keys().contains('lastLogin') || data.lastLogin is timestamp)
        && (!data.keys().contains('firstName') || (data.firstName is string && data.firstName.size() <= 100))
        && (!data.keys().contains('lastName') || (data.lastName is string && data.lastName.size() <= 100))
        && (!data.keys().contains('displayName') || (data.displayName is string && data.displayName.size() <= 256))
        && (!data.keys().contains('username') || (data.username is string && data.username.size() <= 100))
        && (!data.keys().contains('phoneNumber') || (data.phoneNumber is string && data.phoneNumber.size() <= 25))
        && (!data.keys().contains('birthDate') || (data.birthDate is string && data.birthDate.size() <= 25))
        && (!data.keys().contains('gender') || (data.gender is string && data.gender.size() <= 25))
        && (!data.keys().contains('points') || data.points is number)
        && (!data.keys().contains('totalDiscoveries') || data.totalDiscoveries is number)
        && (!data.keys().contains('totalReviews') || data.totalReviews is number)
        && (!data.keys().contains('xpBoosts') || data.xpBoosts is number)
        && (!data.keys().contains('streakCount') || data.streakCount is number)
        && (!data.keys().contains('longestStreak') || data.longestStreak is number)
        && (!data.keys().contains('lastActiveDate') || (data.lastActiveDate is string && data.lastActiveDate.size() <= 50));
    }
    function isValidPublicProfile(data) {
      return (!data.keys().contains('displayName') || (data.displayName is string && data.displayName.size() <= 256))
        && (!data.keys().contains('updatedAt') || data.updatedAt is timestamp)
        && (!data.keys().contains('photoURL') || data.photoURL == null || data.photoURL is string)
        && (!data.keys().contains('username') || (data.username is string && data.username.size() <= 100))
        && (!data.keys().contains('points') || data.points is number)
        && (!data.keys().contains('totalDiscoveries') || data.totalDiscoveries is number)
        && (!data.keys().contains('totalReviews') || data.totalReviews is number)
        && (!data.keys().contains('xpBoosts') || data.xpBoosts is number);
    }
    function isValidLocation(data) {
      return (!data.keys().contains('name') || (data.name is string && data.name.size() > 0 && data.name.size() <= 200))
        && (!data.keys().contains('description') || (data.description is string && data.description.size() > 0 && data.description.size() <= 6000))
        && (!data.keys().contains('continent') || (data.continent in ["Africa", "Asia", "Europe", "North America", "South America", "Oceania", "Antarctica"]))
        && (!data.keys().contains('userId') || (request.auth != null && data.userId == request.auth.uid) || data.userId.startsWith('guest_'))
        && (!data.keys().contains('isDeleted') || data.isDeleted is bool);
    }

    // --- Collection: locations ---
    match /locations/{locationId} {
      allow read: if true; // Publicly viewable

      allow create: if (isVerified() || (incoming().userId is string && incoming().userId.startsWith('guest_')))
        && isValidId(locationId)
        && isValidLocation(incoming());

      allow update: if (isVerified() || (incoming().userId is string && incoming().userId.startsWith('guest_')))
        && isValidId(locationId)
        && isValidLocation(incoming())
        && (isOwner(existing().userId) || existing().userId.startsWith('guest_') || isAdmin())
        && incoming().userId == existing().userId;

      allow delete: if (isVerified() || (existing().userId is string && existing().userId.startsWith('guest_')))
        && isValidId(locationId)
        && (isOwner(existing().userId) || existing().userId.startsWith('guest_') || isAdmin());
    }

    // --- Collection: favorites ---
    match /favorites/{favoriteId} {
      allow read: if (isSignedIn() && resource.data.userId == request.auth.uid) || resource.data.userId.startsWith('guest_');
      
      allow create: if (isVerified() || request.resource.data.userId.startsWith('guest_'))
        && isValidId(favoriteId)
        && (request.resource.data.userId == request.auth.uid || request.resource.data.userId.startsWith('guest_'))
        && request.resource.data.locationId is string
        && request.resource.data.createdAt == request.time;
      
      allow delete: if (isVerified() || existing().userId.startsWith('guest_'))
        && (isOwner(existing().userId) || existing().userId.startsWith('guest_') || isAdmin());
    }

    // --- Collection: reviews ---
    match /reviews/{reviewId} {
      allow read: if true;
      
      allow create: if (isVerified() || request.resource.data.userId.startsWith('guest_'))
        && isValidId(reviewId)
        && (request.resource.data.userId == request.auth.uid || request.resource.data.userId.startsWith('guest_'))
        && request.resource.data.createdAt == request.time
        && request.resource.data.rating >= 1 && request.resource.data.rating <= 5;
        
      allow delete: if (isVerified() || existing().userId.startsWith('guest_'))
        && (isOwner(existing().userId) || existing().userId.startsWith('guest_') || isAdmin());
    }

    // --- Collection: tours (Planned Visits) ---
    match /tours/{tourId} {
      allow read: if (isSignedIn() && resource.data.userId == request.auth.uid) || resource.data.userId.startsWith('guest_');
      
      allow create: if (isVerified() || request.resource.data.userId.startsWith('guest_'))
        && isValidId(tourId)
        && (request.resource.data.userId == request.auth.uid || request.resource.data.userId.startsWith('guest_'))
        && request.resource.data.locationId is string
        && request.resource.data.createdAt == request.time;
      
      allow delete: if (isVerified() || existing().userId.startsWith('guest_'))
        && (isOwner(existing().userId) || existing().userId.startsWith('guest_') || isAdmin());
    }

    // --- Collection: archives ---
    match /archives/{archiveId} {
      allow read: if (isSignedIn() && resource.data.userId == request.auth.uid) || resource.data.userId.startsWith('guest_');
      
      allow create: if (isVerified() || request.resource.data.userId.startsWith('guest_'))
        && isValidId(archiveId)
        && (request.resource.data.userId == request.auth.uid || request.resource.data.userId.startsWith('guest_'))
        && request.resource.data.locationId is string
        && request.resource.data.createdAt == request.time;
      
      allow delete: if (isVerified() || existing().userId.startsWith('guest_'))
        && (isOwner(existing().userId) || existing().userId.startsWith('guest_') || isAdmin());
    }

    // --- Collection: users ---
    match /users/{userId} {
      allow read: if (request.auth != null && request.auth.uid == userId) || userId.startsWith('guest_');
      allow write: if (request.auth != null && request.auth.uid == userId) || userId.startsWith('guest_');
    }

    // --- Collection: public_profiles ---
    match /public_profiles/{userId} {
      allow read: if true;
      allow write: if (request.auth != null && request.auth.uid == userId) || userId.startsWith('guest_');
    }

    // Default deny everything else (Global Fallback)
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
