rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // --- Global Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      return isSignedIn();
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isVerified() && (
        request.auth.token.email == 'mukkuc41@gmail.com' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Validation Helpers ---
    function isValidUserProfile(data) {
      return data.keys().hasAll(['email', 'updatedAt'])
        && data.email is string && data.email.size() <= 256
        && data.updatedAt is timestamp
        && (!data.keys().contains('lastLogin') || data.lastLogin is timestamp)
        && (!data.keys().contains('firstName') || (data.firstName is string && data.firstName.size() <= 100))
        && (!data.keys().contains('lastName') || (data.lastName is string && data.lastName.size() <= 100))
        && (!data.keys().contains('displayName') || (data.displayName is string && data.displayName.size() <= 256))
        && (!data.keys().contains('username') || (data.username is string && data.username.size() <= 100))
        && (!data.keys().contains('phoneNumber') || (data.phoneNumber is string && data.phoneNumber.size() <= 25))
        && (!data.keys().contains('birthDate') || (data.birthDate is string && data.birthDate.size() <= 25))
        && (!data.keys().contains('gender') || (data.gender is string && data.gender.size() <= 25))
        && (!data.keys().contains('points') || data.points is number)
        && (!data.keys().contains('totalDiscoveries') || data.totalDiscoveries is number)
        && (!data.keys().contains('totalReviews') || data.totalReviews is number);
    }
    function isValidPublicProfile(data) {
      return data.keys().hasAll(['displayName', 'updatedAt'])
        && data.displayName is string && data.displayName.size() <= 256
        && data.updatedAt is timestamp
        && (!data.keys().contains('photoURL') || data.photoURL == null || data.photoURL is string)
        && (!data.keys().contains('points') || data.points is number)
        && (!data.keys().contains('totalDiscoveries') || data.totalDiscoveries is number)
        && (!data.keys().contains('totalReviews') || data.totalReviews is number);
    }
    function isValidLocation(data) {
      return data.keys().hasAll(['name', 'description', 'imageUrl', 'continent', 'country', 'state', 'userId', 'userName', 'lat', 'lng', 'createdAt', 'updatedAt'])
        && data.name is string && data.name.size() > 0 && data.name.size() <= 200
        && data.description is string && data.description.size() > 0 && data.description.size() <= 6000
        && data.continent in ["Africa", "Asia", "Europe", "North America", "South America", "Oceania", "Antarctica"]
        && data.userId == request.auth.uid;
    }

    // --- Collection: locations ---
    match /locations/{locationId} {
      allow read: if true; // Publicly viewable

      allow create: if isVerified() 
        && isValidId(locationId)
        && isValidLocation(incoming());

      allow update: if isVerified()
        && isValidId(locationId)
        && (isOwner(existing().userId) || isAdmin())
        && incoming().userId == existing().userId;

      allow delete: if isVerified()
        && isValidId(locationId)
        && (isOwner(existing().userId) || isAdmin());
    }

    // --- Collection: favorites ---
    match /favorites/{favoriteId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      allow create: if isVerified() 
        && isValidId(favoriteId)
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.locationId is string
        && request.resource.data.createdAt == request.time;
      
      allow delete: if isVerified()
        && (isOwner(existing().userId) || isAdmin());
    }

    // --- Collection: reviews ---
    match /reviews/{reviewId} {
      allow read: if true;
      
      allow create: if isVerified()
        && isValidId(reviewId)
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.createdAt == request.time
        && request.resource.data.rating >= 1 && request.resource.data.rating <= 5;
        
      allow delete: if isVerified()
        && (isOwner(existing().userId) || isAdmin());
    }

    // --- Collection: tours (Planned Visits) ---
    match /tours/{tourId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      allow create: if isVerified()
        && isValidId(tourId)
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.locationId is string
        && request.resource.data.createdAt == request.time;
      
      allow delete: if isVerified()
        && (isOwner(existing().userId) || isAdmin());
    }

    // --- Collection: archives ---
    match /archives/{archiveId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      allow create: if isVerified()
        && isValidId(archiveId)
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.locationId is string
        && request.resource.data.createdAt == request.time;
      
      allow delete: if isVerified()
        && (isOwner(existing().userId) || isAdmin());
    }

    // --- Collection: users ---
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // --- Collection: public_profiles ---
    match /public_profiles/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Default deny everything else (Global Fallback)
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
