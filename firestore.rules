rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny everything
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Global Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isVerified() && (
        request.auth.token.email == 'mukkuc41@gmail.com' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Validation Helpers ---
    function isValidUserProfile(data) {
      return data.keys().hasAll(['email', 'updatedAt'])
        && data.email is string && data.email.size() <= 256
        && data.updatedAt == request.time
        && (!data.keys().contains('firstName') || (data.firstName is string && data.firstName.size() <= 100))
        && (!data.keys().contains('lastName') || (data.lastName is string && data.lastName.size() <= 100))
        && (!data.keys().contains('displayName') || (data.displayName is string && data.displayName.size() <= 256))
        && (!data.keys().contains('username') || (data.username is string && data.username.size() <= 100))
        && (!data.keys().contains('phoneNumber') || (data.phoneNumber is string && data.phoneNumber.size() <= 25))
        && (!data.keys().contains('birthDate') || (data.birthDate is string && data.birthDate.size() <= 25))
        && (!data.keys().contains('gender') || (data.gender is string && data.gender.size() <= 25))
        && (!data.keys().contains('points') || data.points is number)
        && (!data.keys().contains('totalDiscoveries') || data.totalDiscoveries is number)
        && (!data.keys().contains('totalReviews') || data.totalReviews is number);
    }
    function isValidPublicProfile(data) {
      return data.keys().hasAll(['displayName', 'updatedAt'])
        && data.displayName is string && data.displayName.size() <= 256
        && data.updatedAt == request.time
        && (!data.keys().contains('photoURL') || (data.photoURL is string && data.photoURL.size() <= 2000))
        && (!data.keys().contains('points') || data.points is number)
        && (!data.keys().contains('totalDiscoveries') || data.totalDiscoveries is number)
        && (!data.keys().contains('totalReviews') || data.totalReviews is number);
    }
    function isValidLocation(data) {
      return data.keys().hasAll(['name', 'description', 'imageUrl', 'continent', 'country', 'state', 'userId', 'userName', 'lat', 'lng', 'createdAt', 'updatedAt'])
        && data.keys().size() == 12
        && data.name is string && data.name.size() > 0 && data.name.size() <= 200
        && data.description is string && data.description.size() > 0 && data.description.size() <= 5000
        && data.imageUrl is string && data.imageUrl.size() > 0 && data.imageUrl.size() <= 2000
        && data.continent in ["Africa", "Asia", "Europe", "North America", "South America", "Oceania", "Antarctica"]
        && data.country is string && data.country.size() > 0 && data.country.size() <= 100
        && data.state is string && data.state.size() > 0 && data.state.size() <= 100
        && data.userId == request.auth.uid
        && data.userName is string && data.userName.size() <= 100
        && data.lat is number
        && data.lng is number
        && data.createdAt == request.time
        && data.updatedAt == request.time;
    }

    // --- Collection: locations ---
    match /locations/{locationId} {
      allow read: if true; // Publicly viewable

      allow create: if isVerified() 
        && isValidId(locationId)
        && isValidLocation(incoming());

      allow update: if isVerified()
        && isValidId(locationId)
        && (isOwner(existing().userId) || isAdmin())
        && incoming().userId == existing().userId
        && incoming().createdAt == existing().createdAt
        && incoming().updatedAt == request.time
        && (
          // Action: Edit Content or Soft Delete
          (incoming().diff(existing()).affectedKeys().hasOnly(['name', 'description', 'imageUrl', 'continent', 'country', 'state', 'updatedAt', 'userName', 'isDeleted', 'deletedAt']))
        )
        && (incoming().isDeleted is bool || !incoming().keys().contains('isDeleted'))
        && incoming().name is string && incoming().name.size() <= 200
        && incoming().description is string && incoming().description.size() <= 5000
        && incoming().imageUrl is string && incoming().imageUrl.size() <= 2000
        && incoming().continent in ["Africa", "Asia", "Europe", "North America", "South America", "Oceania", "Antarctica"]
        && incoming().country is string && incoming().country.size() <= 100
        && incoming().state is string && incoming().state.size() <= 100;

      allow delete: if isVerified()
        && isValidId(locationId)
        && (isOwner(existing().userId) || isAdmin());
    }

    // --- Collection: favorites ---
    match /favorites/{favoriteId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      allow create: if isVerified() 
        && isValidId(favoriteId)
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.locationId is string
        && request.resource.data.createdAt == request.time;
      
      allow delete: if isVerified()
        && (isOwner(existing().userId) || isAdmin());
    }

    // --- Collection: reviews ---
    match /reviews/{reviewId} {
      allow read: if true;
      
      allow create: if isVerified()
        && isValidId(reviewId)
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.createdAt == request.time
        && request.resource.data.rating >= 1 && request.resource.data.rating <= 5;
        
      allow delete: if isVerified()
        && (isOwner(existing().userId) || isAdmin());
    }

    // --- Collection: tours (Planned Visits) ---
    match /tours/{tourId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      allow create: if isVerified()
        && isValidId(tourId)
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.locationId is string
        && request.resource.data.createdAt == request.time;
      
      allow delete: if isVerified()
        && (isOwner(existing().userId) || isAdmin());
    }

    // --- Collection: archives ---
    match /archives/{archiveId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      allow create: if isVerified()
        && isValidId(archiveId)
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.locationId is string
        && request.resource.data.createdAt == request.time;
      
      allow delete: if isVerified()
        && (isOwner(existing().userId) || isAdmin());
    }

    // --- Collection: users ---
    match /users/{userId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      allow write: if isSignedIn() && request.auth.uid == userId && isValidUserProfile(incoming());
    }

    // --- Collection: public_profiles ---
    match /public_profiles/{userId} {
      allow read: if isSignedIn(); // Allow all signed-in users to see leaderboard stats
      allow write: if isSignedIn() && request.auth.uid == userId && isValidPublicProfile(incoming());
    }
  }
}
